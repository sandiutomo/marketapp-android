<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_20"
        android:backgroundTint="@color/text_tertiary"
        android:background="@android:color/white" />

    <!-- App icon header -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_20"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="@color/primary_light"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_splash_logo"
            android:tint="@color/primary"
            android:contentDescription="@null" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_8"
        android:text="@string/consent_title"
        android:textAppearance="@style/TextAppearance.MarketApp.Title2"
        android:textColor="@color/text_primary" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_24"
        android:gravity="center"
        android:text="@string/consent_subtitle"
        android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
        android:textColor="@color/text_secondary" />

    <!-- Permission toggles card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_20"
        app:cardCornerRadius="@dimen/card_radius_large"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Notifications row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_16"
                android:gravity="center_vertical">

                <!-- Icon -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/primary_light"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        android:tint="@color/primary"
                        android:contentDescription="@null" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_16"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/consent_notifications_title"
                        android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:text="@string/consent_notifications_desc"
                        android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>

                <!-- Toggle -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_notifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="72dp"
                android:background="@color/gray_5" />

            <!-- Analytics row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_16"
                android:gravity="center_vertical">

                <!-- Icon -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/primary_light"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        android:tint="@color/primary"
                        android:contentDescription="@null" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_16"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/consent_analytics_title"
                        android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:text="@string/consent_analytics_desc"
                        android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>

                <!-- Toggle -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_analytics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Privacy policy note -->
    <TextView
        android:id="@+id/tv_privacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_20"
        android:text="@string/consent_privacy_note"
        android:textAppearance="@style/TextAppearance.MarketApp.Caption"
        android:textColor="@color/text_tertiary"
        android:gravity="center" />

    <!-- Continue button -->
    <Button
        android:id="@+id/btn_continue"
        style="@style/Widget.MarketApp.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginBottom="@dimen/spacing_8"
        android:text="@string/consent_continue" />

</LinearLayout>