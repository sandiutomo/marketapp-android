<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_24"
                android:paddingBottom="@dimen/spacing_20">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_title"
                    android:textAppearance="@style/TextAppearance.MarketApp.Title1"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- Avatar + name card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_20"
                    android:gravity="center_vertical">

                    <!-- Avatar circle -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardBackgroundColor="@color/primary_light"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <TextView
                            android:id="@+id/tv_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="G"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/primary"
                            android:tag="ph-no-capture" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/guest_user"
                            android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                            android:textColor="@color/text_primary"
                            android:tag="ph-no-capture" />

                        <TextView
                            android:id="@+id/tv_user_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_2"
                            android:text="Tap to sign in"
                            android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
                            android:textColor="@color/text_tertiary"
                            android:tag="ph-no-capture" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right"
                        android:alpha="0.4"
                        android:contentDescription="Edit profile" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Menu groups -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_24"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_profile_row"
                        android:id="@+id/row_orders" />
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                    <include layout="@layout/item_profile_row"
                        android:id="@+id/row_wishlist" />
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                    <include layout="@layout/item_profile_row"
                        android:id="@+id/row_addresses" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_profile_row" android:id="@+id/row_notifications" />
                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                    <include layout="@layout/item_profile_row" android:id="@+id/row_settings" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Debug panel (shown only in debug builds via ProfileFragment) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_debug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <!-- ── DEVELOPER TOOLS header ──────────────────────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVELOPER TOOLS"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.05" />

                    <!-- ── Utility row ─────────────────────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_debug_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/background"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔍"
                                    android:textSize="20sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="SDK &amp; Flag Status"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/text_primary"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space android:layout_width="8dp" android:layout_height="0dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_force_refresh"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/background"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔄"
                                    android:textSize="20sp" />
                                <TextView
                                    android:id="@+id/tv_force_refresh_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/debug_force_refresh_flags"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/text_primary"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- ── BRAZE TRIGGERS ──────────────────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            app:cardBackgroundColor="@color/braze_dot"
                            app:cardCornerRadius="4dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="BRAZE TRIGGERS"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.03" />
                    </LinearLayout>

                    <!-- Braze row 1: Push + Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_trigger_push"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/braze_purple_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="12dp"
                                android:text="Push"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/braze_purple_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                        <Space android:layout_width="8dp" android:layout_height="0dp" />
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_trigger_banner"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/braze_purple_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="12dp"
                                android:text="Banner"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/braze_purple_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Braze row 2: In-app + Content card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_trigger_inapp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/braze_purple_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="12dp"
                                android:text="In-app message"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/braze_purple_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                        <Space android:layout_width="8dp" android:layout_height="0dp" />
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_trigger_content_card"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/braze_purple_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="12dp"
                                android:text="Content card"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/braze_purple_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Clear Braze cache -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_braze_cache"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Clear Braze cache"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        app:strokeColor="@color/gray_4"
                        app:cornerRadius="@dimen/card_radius"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <!-- ── AMPLITUDE ────────────────────────────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            app:cardBackgroundColor="@color/amplitude_dot"
                            app:cardCornerRadius="4dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="AMPLITUDE"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.03" />
                    </LinearLayout>

                    <!-- Amplitude 3-column row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_trigger_guide"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/amplitude_blue_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="8dp"
                                android:text="Guide trigger"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/amplitude_blue_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                        <Space android:layout_width="8dp" android:layout_height="0dp" />
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_preview_guide"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/amplitude_blue_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="8dp"
                                android:text="Preview guide"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/amplitude_blue_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                        <Space android:layout_width="8dp" android:layout_height="0dp" />
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_preview_survey"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@color/amplitude_blue_bg"
                            app:cardCornerRadius="@dimen/card_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="8dp"
                                android:text="Preview survey"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/amplitude_blue_text"
                                android:gravity="center" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Sign out -->
            <Button
                android:id="@+id/btn_sign_out"
                style="@style/Widget.MarketApp.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_24"
                android:text="@string/sign_out"
                android:textColor="@color/error" />

            <!-- Version -->
            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_16"
                android:layout_marginBottom="@dimen/spacing_32"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Braze profile banner — floats over content at the bottom of the screen -->
    <FrameLayout
        android:id="@+id/banner_container_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/spacing_16"
        android:elevation="4dp"
        android:visibility="gone">

        <com.braze.ui.banners.BannerView
            android:id="@+id/braze_banner_profile"
            android:layout_width="match_parent"
            android:layout_height="@dimen/banner_max_height"
            app:placementId="profile_banner" />

        <ImageButton
            android:id="@+id/btn_close_banner_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@drawable/ic_close"
            android:tint="@color/text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close banner" />

    </FrameLayout>

</FrameLayout>
