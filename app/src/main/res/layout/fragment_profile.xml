<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="@dimen/spacing_24"
            android:paddingBottom="@dimen/spacing_20">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_title"
                android:textAppearance="@style/TextAppearance.MarketApp.Title1"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- Avatar + name card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_20"
                android:gravity="center_vertical">

                <!-- Avatar circle -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@color/primary_light"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <TextView
                        android:id="@+id/tv_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="G"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary"
                        android:tag="ph-no-capture" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_16"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/guest_user"
                        android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                        android:textColor="@color/text_primary"
                        android:tag="ph-no-capture" />

                    <TextView
                        android:id="@+id/tv_user_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2"
                        android:text="Tap to sign in"
                        android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
                        android:textColor="@color/text_tertiary"
                        android:tag="ph-no-capture" />

                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:alpha="0.4"
                    android:contentDescription="Edit profile" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Menu groups -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding"
            android:layout_marginTop="@dimen/spacing_24"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/item_profile_row"
                    android:id="@+id/row_orders" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                <include layout="@layout/item_profile_row"
                    android:id="@+id/row_wishlist" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                <include layout="@layout/item_profile_row"
                    android:id="@+id/row_addresses" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding"
            android:layout_marginTop="@dimen/spacing_16"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/item_profile_row" android:id="@+id/row_notifications" />
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/gray_5" android:layout_marginStart="56dp" />
                <include layout="@layout/item_profile_row" android:id="@+id/row_settings" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Debug panel (shown only in debug builds via ProfileFragment) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_debug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding"
            android:layout_marginTop="@dimen/spacing_16"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/card_radius_large"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <Button
                    android:id="@+id/btn_debug_info"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="SDK &amp; Flag Status" />

                <Button
                    android:id="@+id/btn_trigger_push"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/debug_trigger_push" />

                <Button
                    android:id="@+id/btn_trigger_banner"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/debug_trigger_banner" />

                <Button
                    android:id="@+id/btn_trigger_inapp"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/debug_trigger_inapp" />

                <Button
                    android:id="@+id/btn_trigger_content_card"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/debug_trigger_content_card" />

                <Button
                    android:id="@+id/btn_clear_braze_cache"
                    style="@style/Widget.MarketApp.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/debug_clear_braze_cache" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Sign out -->
        <Button
            android:id="@+id/btn_sign_out"
            style="@style/Widget.MarketApp.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/screen_padding"
            android:layout_marginTop="@dimen/spacing_24"
            android:text="@string/sign_out"
            android:textColor="@color/error" />

        <!-- Version -->
        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_16"
            android:layout_marginBottom="@dimen/spacing_32"
            android:textAppearance="@style/TextAppearance.MarketApp.Caption"
            android:textColor="@color/text_tertiary" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
