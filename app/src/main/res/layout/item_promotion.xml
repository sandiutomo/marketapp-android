<?xml version="1.0" encoding="utf-8"?>
<!-- Promotion banner card: light surface with bold accent panel on the right -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="160dp"
    android:layout_marginEnd="@dimen/spacing_12"
    android:layout_marginTop="@dimen/spacing_12"
    android:layout_marginBottom="@dimen/spacing_12"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeColor="@color/gray_5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left text area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Category label badge -->
            <TextView
                android:id="@+id/tv_promo_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_promo_label"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="@android:color/white" />

            <!-- Headline -->
            <TextView
                android:id="@+id/tv_promo_name"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.15"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/text_primary"
                android:maxLines="3"
                android:ellipsize="end"
                android:gravity="top" />

            <!-- Shop Now pill CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_shop_now"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Shop Now"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                app:backgroundTint="#00C06A"
                app:cornerRadius="20dp" />

        </LinearLayout>

        <!-- Right accent panel — color set programmatically, clipped by card corners -->
        <LinearLayout
            android:id="@+id/accent_panel"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1ED760">

            <!-- Large discount % -->
            <TextView
                android:id="@+id/tv_discount_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textSize="30sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="#CCFFFFFF"
                android:gravity="center" />

            <View
                android:layout_width="24dp"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#66FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textSize="9sp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.1"
                android:textColor="#99FFFFFF"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
