<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.MarketApp.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/primary"
            app:menu="@menu/menu_product_detail" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Product Image -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_8"
                app:cardCornerRadius="@dimen/card_radius_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <ImageView
                    android:id="@+id/img_product"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="32dp"
                    android:contentDescription="Product image" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Product Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_20"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:textAppearance="@style/TextAppearance.MarketApp.Title2"
                    android:textColor="@color/text_primary"
                    android:maxLines="3"
                    android:ellipsize="end" />

                <!-- Price + stock badge on same row, never overlapping -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="@style/TextAppearance.MarketApp.Title2"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_in_stock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/in_stock"
                        android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
                        android:textColor="@color/success" />

                </LinearLayout>

                <!-- Rating row -->
                <LinearLayout
                    android:id="@+id/rating_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star_filled"
                        android:contentDescription="Star" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_4"
                        android:textAppearance="@style/TextAppearance.MarketApp.Subheadline"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_review_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_4"
                        android:textAppearance="@style/TextAppearance.MarketApp.Subheadline"
                        android:textColor="@color/text_tertiary" />

                </LinearLayout>

                <!-- Shipping estimate — value from Firebase Remote Config max_shipping_days -->
                <TextView
                    android:id="@+id/tv_shipping_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_20"
                android:background="@color/gray_5" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_20"
                android:text="@string/product_description"
                android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_8"
                android:lineSpacingExtra="4dp"
                android:textAppearance="@style/TextAppearance.MarketApp.Body"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Bottom CTA -->
    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/spacing_12"
        android:paddingBottom="@dimen/spacing_24">

        <!-- Wishlist button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wishlist"
            style="@style/Widget.MarketApp.Button.Secondary"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="@dimen/spacing_12"
            android:padding="0dp"
            app:icon="@drawable/ic_heart"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <Button
            android:id="@+id/btn_add_to_cart"
            style="@style/Widget.MarketApp.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/add_to_cart" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
