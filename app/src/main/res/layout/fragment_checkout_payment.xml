<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.MarketApp.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/primary"
        app:title="@string/payment_method" />

    <!-- PostHog flag: checkout-progress-bar — step 2 = 100% complete -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/checkout_progress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:indicatorColor="@color/primary"
        app:trackCornerRadius="0dp"
        android:progress="100" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/place_order_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/checkout_progress">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <!-- Step indicator -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 2 of 2 — Payment"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="@dimen/spacing_16" />

            <!-- Payment Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/payment_method"
                android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="@dimen/spacing_12" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <RadioGroup
                    android:id="@+id/rg_payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_8">

                    <RadioButton
                        android:id="@+id/rb_card"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Credit / Debit Card"
                        android:checked="true"
                        android:paddingStart="@dimen/spacing_8"
                        android:buttonTint="@color/primary"
                        android:textAppearance="@style/TextAppearance.MarketApp.Body" />

                    <RadioButton
                        android:id="@+id/rb_paypal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="PayPal"
                        android:paddingStart="@dimen/spacing_8"
                        android:buttonTint="@color/primary"
                        android:textAppearance="@style/TextAppearance.MarketApp.Body" />

                    <RadioButton
                        android:id="@+id/rb_googlepay"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Google Pay"
                        android:paddingStart="@dimen/spacing_8"
                        android:buttonTint="@color/primary"
                        android:textAppearance="@style/TextAppearance.MarketApp.Body" />

                    <RadioButton
                        android:id="@+id/rb_cod"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Cash on Delivery"
                        android:paddingStart="@dimen/spacing_8"
                        android:buttonTint="@color/primary"
                        android:textAppearance="@style/TextAppearance.MarketApp.Body" />

                </RadioGroup>

            </com.google.android.material.card.MaterialCardView>

            <!-- Order Summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/order_summary"
                android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                android:textColor="@color/text_primary"
                android:layout_marginTop="@dimen/spacing_24"
                android:layout_marginBottom="@dimen/spacing_12" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal"
                            android:textAppearance="@style/TextAppearance.MarketApp.Body"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tv_subtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.MarketApp.Body"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/spacing_8">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Shipping"
                            android:textAppearance="@style/TextAppearance.MarketApp.Body"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tv_shipping"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.MarketApp.Body" />
                    </LinearLayout>

                    <!-- Shipping estimate — value from Firebase Remote Config max_shipping_days -->
                    <TextView
                        android:id="@+id/tv_shipping_days"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4"
                        android:textAppearance="@style/TextAppearance.MarketApp.Footnote"
                        android:textColor="@color/text_tertiary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/gray_5"
                        android:layout_marginVertical="@dimen/spacing_12" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total"
                            android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                            android:textColor="@color/text_primary" />
                        <TextView
                            android:id="@+id/tv_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.MarketApp.Headline"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/place_order_btn"
        style="@style/Widget.MarketApp.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/spacing_24"
        android:text="@string/place_order"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>