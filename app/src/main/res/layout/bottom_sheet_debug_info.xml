<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@color/gray_5" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingTop="@dimen/spacing_16"
        android:paddingBottom="@dimen/spacing_12">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Debug Info"
            android:textAppearance="@style/TextAppearance.MarketApp.Title1"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btn_refresh"
            style="@style/Widget.MarketApp.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="@dimen/spacing_16"
            android:text="Refresh"
            android:textSize="13sp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ SECTION HEADER: USER ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12"
                android:text="USER"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/text_primary"
                android:background="@color/gray_5" />

            <LinearLayout
                android:id="@+id/container_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ═══ SECTION HEADER: DEVICE ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="DEVICE"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/text_primary"
                android:background="@color/gray_5" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Device Tokens"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:id="@+id/container_tokens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ═══ SECTION HEADER: SESSION REPLAY ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="SESSION REPLAY"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/text_primary"
                android:background="@color/gray_5" />

            <LinearLayout
                android:id="@+id/container_session_replay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ═══ SECTION HEADER: FEATURE FLAGS ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="FEATURE FLAGS"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/text_primary"
                android:background="@color/gray_5" />

            <!-- SDK Gates — Statsig managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Statsig SDK Gates"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_statsig"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_sdks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Rollouts — Statsig managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Statsig Feature Rollouts"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_statsig"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_rollouts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Flags — Firebase Remote Config managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Firebase Remote Config"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_firebase"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_flags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Flags — PostHog managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="PostHog Feature Flags"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_posthog"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_posthog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Flags — Braze managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Braze Feature Flags"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_braze"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_braze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Flags — Amplitude Experiment managed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Amplitude Experiment"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_amplitude"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_amplitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Feature Flags — Mixpanel -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Mixpanel"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04" />

            <LinearLayout
                android:id="@+id/container_mixpanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- ═══ SECTION HEADER: CAMPAIGN STATUS ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12"
                android:layout_marginTop="@dimen/spacing_16"
                android:text="CAMPAIGN STATUS"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/text_primary"
                android:background="@color/gray_5" />

            <!-- Braze Content Cards -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Braze Content Cards"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_braze"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_content_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Braze Canvas Content Cards -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Braze Canvas Content Cards"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_braze"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_braze_canvas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Braze Banner Placements -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Braze Banner Placements"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_braze"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_banners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- Braze Push Subscription -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="Braze Push Subscription"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_braze"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_braze_push"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="@dimen/screen_padding"
                android:layout_marginTop="@dimen/spacing_16"
                android:background="@color/gray_5" />

            <!-- OneSignal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/screen_padding"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_8"
                android:text="OneSignal"
                android:textAppearance="@style/TextAppearance.MarketApp.Caption"
                android:textColor="@color/text_tertiary"
                android:letterSpacing="0.04"
                android:drawableStart="@drawable/ic_platform_onesignal"
                android:drawablePadding="6dp"
                android:gravity="center_vertical" />

            <LinearLayout
                android:id="@+id/container_onesignal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>